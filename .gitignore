# Ignore everything by default
/*

# Keep repository metadata and publishable files
!.gitignore
!README.md
!pyproject.toml
!uv.lock
!run_augmentation.sh
!main.py
!.github/
.github/*
!.github/workflows/
.github/workflows/*
!.github/workflows/smoke.yml

# Keep only the core package entry points
!src/
src/*
!src/__init__.py
!src/main_aug.py
